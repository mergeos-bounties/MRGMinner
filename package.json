{
  "name": "mrgminner",
  "displayName": "MRGMinner",
  "version": "0.4.0",
  "private": true,
  "description": "MRGMinner \u2014 MergeOS miner: discoverable MRG chain, work-split packs, claim intents, Solana proof anchors, claim-block clusters, VS Code bridge.",
  "main": "./src/extension.js",
  "bin": {
    "mrgminner": "./bin/mrgminner.js",
    "mergeide": "./bin/mrgminner.js"
  },
  "scripts": {
    "start": "node ./bin/mrgminner.js",
    "tasks": "node ./bin/mrgminner.js tasks",
    "test": "node --test",
    "build:exe": "pkg . --targets node22-win-x64 --compress GZip --output dist/MRGMinner-Windows-x64.exe"
  },
  "keywords": [
    "mergeos",
    "mrg",
    "mrgminner",
    "blockchain",
    "ledger",
    "solana",
    "bounty",
    "vscode",
    "agent"
  ],
  "engines": {
    "node": ">=18.17.0",
    "vscode": "^1.90.0"
  },
  "activationEvents": [
    "onCommand:mergeide.showTasks",
    "onCommand:mergeide.runTask",
    "onCommand:mergeide.claimTask",
    "onCommand:mergeide.submitTask",
    "onCommand:mergeide.configureAiCli"
  ],
  "contributes": {
    "commands": [
      {
        "command": "mergeide.showTasks",
        "title": "MRGMinner: Show MergeOS Tasks"
      },
      {
        "command": "mergeide.runTask",
        "title": "MRGMinner: Run Task With AI CLI"
      },
      {
        "command": "mergeide.claimTask",
        "title": "MRGMinner: Claim Task"
      },
      {
        "command": "mergeide.submitTask",
        "title": "MRGMinner: Submit Task Evidence"
      },
      {
        "command": "mergeide.configureAiCli",
        "title": "MRGMinner: Configure AI CLI"
      }
    ],
    "configuration": {
      "title": "MRGMinner",
      "properties": {
        "mergeide.mergeosUrl": {
          "type": "string",
          "default": "http://localhost:8080",
          "description": "MergeOS API base URL."
        },
        "mergeide.token": {
          "type": "string",
          "default": "",
          "description": "MergeOS auth token. Prefer the user settings file or environment variable for real tokens."
        },
        "mergeide.aiProvider": {
          "type": "string",
          "default": "codex",
          "enum": [
            "codex",
            "claude",
            "custom"
          ],
          "description": "AI CLI preset used by MRGMinner."
        },
        "mergeide.aiCommand": {
          "type": "string",
          "default": "",
          "description": "Command to launch the AI CLI. Empty uses the selected preset."
        },
        "mergeide.aiArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Arguments for the AI CLI. Supports {{prompt}}, {{promptFile}}, {{taskFile}}, and {{taskId}}."
        },
        "mergeide.workspaceRoot": {
          "type": "string",
          "default": "",
          "description": "Workspace where the AI CLI should run. Empty uses the current VS Code workspace."
        },
        "mergeide.workerId": {
          "type": "string",
          "default": "mergeide:local",
          "description": "Worker identity used when claiming MergeOS tasks."
        },
        "mergeide.agentType": {
          "type": "string",
          "default": "mergeide",
          "description": "Agent type sent to MergeOS for agent or hybrid tasks."
        },
        "mergeide.autoClaimAfterRun": {
          "type": "boolean",
          "default": false,
          "description": "Reserve the task lane after the AI CLI exits successfully. This does not release payout."
        }
      }
    }
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.20.0"
  }
}
